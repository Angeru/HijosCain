<%= form_with(url: sessions_path, local: true) do |form| %>
  <% if flash[:error] %>
    <div style="color: red">
      <h2><%= flash[:error] %></h2>
    </div>
  <% end %>

<div id="root">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-8">
      <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-indigo-600 rounded-full mb-4">
          <i class="ri-group-line text-3xl text-white"></i>
        </div>
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Hijos de Caín</h1>
        <p class="text-gray-600">Sistema Interno de Administración</p>
      </div>
      <form class="space-y-6">
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Nombre de usuario</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none w-5 h-5">
              <i class="ri-id-card-line text-gray-400"></i>
            </div>
            <%= form.text_field :username, class: "block w-full pl-10 pr-3 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm" %>
          </div>
        </div>
        <div>
          <label for="password" class="block text-sm font-medium text-gray-700 mb-2">Contraseña</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none w-5 h-5">
              <i class="ri-lock-line text-gray-400"></i>
            </div>
             <%= form.password_field :password, class: "block w-full pl-10 pr-3 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm" %>
          </div>
        </div>
        <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-3 px-4 rounded-lg transition-colors duration-200 disabled:opacity-50 disabled:cursor-not-allowed whitespace-nowrap">Iniciar Sesión</button>
      </form>
      <div class="mt-6 text-center">
        <p class="text-sm text-gray-600">Sistema de uso exclusivo para miembros autorizados</p>
      </div>
    </div>
  </div>
</div>



<% end %>