<div id="root">
  <div class="min-h-screen bg-gray-50">
    <header class="bg-white shadow-sm border-b border-gray-200">
      <div class="px-6 py-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-4">
            <a href="/"><button class="w-10 h-10 flex items-center justify-center hover:bg-gray-100 rounded-lg transition-colors cursor-pointer"><i class="ri-arrow-left-line text-xl text-gray-700"></i></button></a>
            <div>
              <h1 class="text-xl font-bold text-gray-900">Tipos de Artículo</h1>
              <p class="text-sm text-gray-600">Catálogo de tipos de artículos</p>
            </div>
          </div>
          <a href="/good_types/new"><button class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg flex items-center space-x-2 transition-colors whitespace-nowrap cursor-pointer"><i class="ri-add-line mr-1"></i><span>Nuevo Tipo</span></button></a>
        </div>
      </div>
    </header>

    <div class="p-6">

      <% if notice.present? %>
        <div class="mb-4 bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg text-sm"><i class="ri-checkbox-circle-fill mr-2"></i><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="mb-4 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg text-sm"><i class="ri-error-warning-fill mr-2"></i><%= alert %></div>
      <% end %>

      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-50 border-b border-gray-200">
              <tr>
                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Nombre</th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Artículos</th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Acciones</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <% @good_types.each do |good_type| %>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-4"><span class="text-sm font-medium text-gray-900"><%= good_type.name %></span></td>
                  <td class="px-6 py-4 whitespace-nowrap"><span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800"><%= good_type.goods.count %></span></td>
                  <td class="px-6 py-4 whitespace-nowrap flex items-center space-x-3">
                    <a href="/good_types/<%= good_type.id %>/edit" class="text-indigo-600 hover:text-indigo-900 font-medium text-sm cursor-pointer">Editar</a>
                    <%= button_to good_type_path(good_type), method: :delete,
                          data: { turbo_confirm: "¿Eliminar el tipo «#{good_type.name}»?" },
                          class: "text-red-600 hover:text-red-900 font-medium text-sm cursor-pointer bg-transparent border-0 p-0" do %>
                      Eliminar
                    <% end %>
                  </td>
                </tr>
              <% end %>
              <% if @good_types.empty? %>
                <tr>
                  <td colspan="3" class="px-6 py-8 text-center text-sm text-gray-500">No hay tipos de artículo registrados.</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
