<div id="root">
  <div class="min-h-screen bg-gray-50">
    <header class="bg-white shadow-sm border-b border-gray-200">
      <div class="px-6 py-4">
        <div class="flex items-center space-x-4">
          <a href="<%= mesas_path %>"><button class="w-10 h-10 flex items-center justify-center hover:bg-gray-100 rounded-lg transition-colors cursor-pointer"><i class="ri-arrow-left-line text-xl text-gray-700"></i></button></a>
          <div>
            <h1 class="text-xl font-bold text-gray-900">Nuevo Evento</h1>
            <p class="text-sm text-gray-600">Añadir al calendario de la asociación</p>
          </div>
        </div>
      </div>
    </header>

    <%= form_with url: mesas_path, method: :post do |f| %>
      <div class="p-6">

        <% if flash[:alert].present? %>
          <div class="mb-4 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg text-sm">
            <i class="ri-error-warning-fill mr-2"></i><%= flash[:alert] %>
          </div>
        <% end %>

        <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100 space-y-6">

          <%# Fecha y horas %>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Día</label>
              <%= f.date_field :date, value: Date.today, required: true,
                    class: "block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Hora de inicio</label>
              <%= f.time_field :start_time, required: true,
                    class: "block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Hora de fin</label>
              <%= f.time_field :end_time, required: true,
                    class: "block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
            </div>
          </div>

          <%# Actividad %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Título de la actividad</label>
            <%= f.text_field :title, required: true, placeholder: "Ej: Infinity, Blood Bowl…",
                  class: "block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Descripción <span class="text-gray-400 font-normal">(opcional)</span>
            </label>
            <%= f.text_area :description, rows: 3, placeholder: "Información adicional sobre la actividad…",
                  class: "block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
          </div>

          <%# Mesas %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Mesas que ocupa</label>
            <%= f.select :mesas,
                  [["1 mesa", "1 mesa"], ["2 mesas", "2 mesas"], ["3 mesas", "3 mesas"], ["4 mesas", "4 mesas"], ["Sala grande", "Sala grande"]],
                  { selected: "1 mesa" },
                  { class: "block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" } %>
          </div>

        </div>

        <div class="mt-6">
          <%= f.submit "Crear Evento", class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg font-medium transition-colors cursor-pointer" %>
        </div>

      </div>
    <% end %>
  </div>
</div>
