<div id="root">
    <div class="min-h-screen bg-gray-50">
        <header class="bg-white shadow-sm border-b border-gray-200">
            <div class="px-6 py-4">
                <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 bg-indigo-600 rounded-lg flex items-center justify-center"><i class="ri-group-line text-xl text-white"></i></div>
                        <div>
                            <h1 class="text-xl font-bold text-gray-900">Gestión de Hijos de Caín</h1>
                            <p class="text-sm text-gray-600">Panel de Administración</p>
                        </div>
                    </div><a href="/sessions/destroy"><button class="flex items-center space-x-2 px-4 py-2 text-gray-700 hover:bg-gray-100 rounded-lg transition-colors whitespace-nowrap cursor-pointer"><i class="ri-logout-box-line"></i><span>Cerrar Sesión</span></button></a></div>
            </div>
        </header>
        <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 mb-8">
                <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center"><i class="ri-group-line text-2xl text-blue-600"></i></div>
                    </div>
                    <h3 class="text-2xl font-bold text-gray-900 mb-1"><%= @total_members %></h3>
                    <p class="text-sm text-gray-600">Total Miembros</p>
                </div>
                <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center"><i class="ri-checkbox-circle-line text-2xl text-green-600"></i></div>
                    </div>
                    <h3 class="text-2xl font-bold text-gray-900 mb-1"><%= @no_debt_members %></h3>
                    <p class="text-sm text-gray-600">Al Corriente</p>
                </div>
                <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center"><i class="ri-alert-line text-2xl text-orange-600"></i></div>
                    </div>
                    <h3 class="text-2xl font-bold text-gray-900 mb-1"><%= @debt_members %></h3>
                    <p class="text-sm text-gray-600">Pagos Pendientes</p>
                </div>
                <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center"><i class="ri-shopping-bag-line text-2xl text-purple-600"></i></div>
                    </div>
                    <h3 class="text-2xl font-bold text-gray-900 mb-1"><%= @storage %></h3>
                    <p class="text-sm text-gray-600">Artículos</p>
                </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <% if current_user.has_role? %>
                <div class="bg-white rounded-xl shadow-sm p-8 border border-gray-100 hover:shadow-md transition-shadow cursor-pointer group">
                    <div class="flex items-start space-x-4">
                        <div class="w-16 h-16 bg-indigo-100 rounded-xl flex items-center justify-center group-hover:bg-indigo-600 transition-colors"><i class="ri-user-line text-3xl text-indigo-600 group-hover:text-white"></i></div>
                        <div class="flex-1">
                            <h2 class="text-xl font-bold text-gray-900 mb-2">Gestión de Miembros</h2>
                            <p class="text-gray-600 mb-4">Administra la base de datos de miembros, consulta información personal, estado de pagos y más.</p>
                            <a href="/members" class="flex items-center text-indigo-600 font-medium"><span>Acceder</span><i class="ri-arrow-right-line ml-2"></i></a>
                        </div>
                    </div>
                </div>
                <% end %>
                <% if current_user.has_role? %>
                <div class="bg-white rounded-xl shadow-sm p-8 border border-gray-100 hover:shadow-md transition-shadow cursor-pointer group">
                    <div class="flex items-start space-x-4">
                        <div class="w-16 h-16 bg-purple-100 rounded-xl flex items-center justify-center group-hover:bg-purple-600 transition-colors"><i class="ri-store-line text-3xl text-purple-600 group-hover:text-white"></i></div>
                        <div class="flex-1">
                            <h2 class="text-xl font-bold text-gray-900 mb-2">Gestión de Artículos</h2>
                            <p class="text-gray-600 mb-4">Control de inventario.</p>
                            <div class="flex items-center text-purple-600 font-medium">
                              <a href="/goods">
                                <span>Acceder</span>
                                <i class="ri-arrow-right-line ml-2"></i>
                              </a>
                            </div>
                        </div>
                    </div>
                </div>
                <% end %>
                <% if current_user.president_or_treasurer? %>
                <div class="bg-white rounded-xl shadow-sm p-8 border border-gray-100 hover:shadow-md transition-shadow cursor-pointer group">
                    <div class="flex items-start space-x-4">
                        <div class="w-16 h-16 bg-purple-100 rounded-xl flex items-center justify-center group-hover:bg-purple-600 transition-colors">
                          <i class="ri-money-euro-circle-fill text-3xl text-purple-600 group-hover:text-white"></i>
                        </div>
                        <div class="flex-1">
                            <h2 class="text-xl font-bold text-gray-900 mb-2">Gestión de cobros</h2>
                            <p class="text-gray-600 mb-4">Control de cobros.</p>
                            <div class="flex items-center text-purple-600 font-medium">
                              <a href="/quotes">
                                <span>Acceder</span>
                                <i class="ri-arrow-right-line ml-2"></i>
                              </a>
                            </div>
                        </div>
                    </div>
                </div>
                <% end %>
                <div class="bg-white rounded-xl shadow-sm p-8 border border-gray-100 hover:shadow-md transition-shadow cursor-pointer group">
                    <div class="flex items-start space-x-4">
                        <div class="w-16 h-16 bg-purple-100 rounded-xl flex items-center justify-center group-hover:bg-purple-600 transition-colors">
                          <i class="ri-calendar-todo-fill text-3xl text-purple-600 group-hover:text-white"></i>
                        </div>
                        <div class="flex-1">
                            <h2 class="text-xl font-bold text-gray-900 mb-2">Gestión de mesas</h2>
                            <p class="text-gray-600 mb-4">Control de mesas y calendario.</p>
                            <div class="flex items-center text-purple-600 font-medium">
                              <a href="/mesas">
                                <span>Acceder</span>
                                <i class="ri-arrow-right-line ml-2"></i>
                              </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
