<%= form_with model: good do |f| %>
  <div class="p-6">
    <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
      <% if good.errors.any? %>
        <div class="mb-4 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg text-sm">
          <ul class="list-disc list-inside">
            <% good.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= f.label :nombre, "Nombre", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :nombre, class: "block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
        </div>

        <div>
          <%= f.label :good_type_id, "Tipo", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.collection_select :good_type_id, GoodType.order(:name), :id, :name,
                { prompt: "Selecciona un tipo" },
                { class: "block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" } %>
        </div>

        <div>
          <%= f.label :ean, "EAN", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :ean, class: "block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
        </div>

        <div>
          <%= f.label :unidades, "Unidades", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.number_field :unidades, min: 0, class: "block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
        </div>

        <div class="md:col-span-2">
          <%= f.label :notas, "Notas", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_area :notas, rows: 3, class: "block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
        </div>

        <div class="flex items-center space-x-3">
          <%= f.check_box :cedido, class: "h-4 w-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500" %>
          <%= f.label :cedido, "Cedido", class: "text-sm font-medium text-gray-700" %>
        </div>
      </div>
    </div>

    <div class="mt-6 flex space-x-3">
      <%= f.submit button_label, class: "flex-1 bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg font-medium transition-colors cursor-pointer" %>
    </div>
  </div>
<% end %>
