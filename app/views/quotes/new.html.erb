<div id="root">
  <div class="min-h-screen bg-gray-50">
    <header class="bg-white shadow-sm border-b border-gray-200">
      <div class="px-6 py-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-4">
            <a href="/quotes"><button class="w-10 h-10 flex items-center justify-center hover:bg-gray-100 rounded-lg transition-colors cursor-pointer"><i class="ri-arrow-left-line text-xl text-gray-700"></i></button></a>
            <div>
              <h1 class="text-xl font-bold text-gray-900">Nueva Cuota</h1>
              <p class="text-sm text-gray-600">Cuotas periódicas de la asociación</p>
            </div>
          </div>
        </div>
      </div>
    </header>

    <%= form_with model: @quote do |f| %>
      <div class="p-6">
        <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">Descripción</label>
              <p class="text-base text-gray-900"><%= f.text_field :description %></p>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Importe (€)</label>
              <p class="text-base text-gray-900"><%= f.number_field :amount, step: "0.01" %></p>
            </div>
            <div></div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Fecha de Inicio</label>
              <p class="text-base text-gray-900"><%= f.date_field :start_date %></p>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Fecha de Fin</label>
              <p class="text-base text-gray-900"><%= f.date_field :end_date %></p>
            </div>
          </div>
        </div>
        <div class="mt-6 flex space-x-3">
          <button class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg font-medium transition-colors whitespace-nowrap cursor-pointer"><i class="ri-save-line mr-2"></i>Crear</button>
        </div>
      </div>
    <% end %>
  </div>
</div>
