<div id="root">
  <div class="min-h-screen bg-gray-50">
    <header class="bg-white shadow-sm border-b border-gray-200">
      <div class="px-6 py-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-4">
            <a href="<%= quotes_path %>"><button class="w-10 h-10 flex items-center justify-center hover:bg-gray-100 rounded-lg transition-colors cursor-pointer"><i class="ri-arrow-left-line text-xl text-gray-700"></i></button></a>
            <div>
              <h1 class="text-xl font-bold text-gray-900"><%= @quote.description %></h1>
              <p class="text-sm text-gray-600"><%= @quote.start_date&.strftime("%d/%m/%Y") %> – <%= @quote.end_date&.strftime("%d/%m/%Y") %></p>
            </div>
          </div>
          <div class="flex items-center space-x-3">
            <%= button_to  generate_charges_quote_path(@quote), method: :post, class: "bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg flex items-center space-x-2 transition-colors whitespace-nowrap cursor-pointer", form: { data: { turbo: false } } do %>
              <i class="ri-money-euro-circle-line mr-1"></i> Generar Cargos
            <% end %>
            <a href="<%= edit_quote_path(@quote) %>"><button class="bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2 rounded-lg flex items-center space-x-2 transition-colors whitespace-nowrap cursor-pointer"><i class="ri-edit-line mr-1"></i><span>Editar</span></button></a>
          </div>
        </div>
      </div>
    </header>

    <div class="p-6 space-y-6">

      <%# Flash notice %>
      <% if notice.present? %>
        <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg text-sm"><i class="ri-checkbox-circle-fill mr-2"></i><%= notice %></div>
      <% end %>

      <%# Quote details card %>
      <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
        <h2 class="text-base font-semibold text-gray-900 mb-4">Datos de la cuota</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Descripción</p>
            <p class="text-sm text-gray-900"><%= @quote.description %></p>
          </div>
          <div>
            <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Importe</p>
            <p class="text-sm font-semibold text-gray-900"><%= number_to_currency(@quote.amount, unit: "€", separator: ",", delimiter: ".", format: "%n %u") %></p>
          </div>
          <div>
            <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Período</p>
            <p class="text-sm text-gray-900"><%= @quote.start_date&.strftime("%d/%m/%Y") %> – <%= @quote.end_date&.strftime("%d/%m/%Y") %></p>
          </div>
        </div>
      </div>

      <%# Charges table %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
          <h2 class="text-base font-semibold text-gray-900">Cargos (<%= @quote.charges.count %>)</h2>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-50 border-b border-gray-200">
              <tr>
                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Miembro</th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Importe</th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Fecha de Pago</th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Estado</th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Notas</th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Acciones</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <% @quote.charges.includes(:member).each do |charge| %>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-4">
                    <div class="text-sm font-medium text-gray-900"><%= charge.member.full_name %></div>
                    <div class="text-xs text-gray-500">Nº <%= charge.member.number %></div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-900"><%= number_to_currency(charge.amount || @quote.amount, unit: "€", separator: ",", delimiter: ".", format: "%n %u") %></span></td>
                  <td class="px-6 py-4 whitespace-nowrap"><span class="text-sm text-gray-900"><%= charge.charge_date&.strftime("%d/%m/%Y") || "—" %></span></td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% if charge.charge_date.present? %>
                      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800"><i class="ri-checkbox-circle-fill mr-1"></i>Pagado</span>
                    <% else %>
                      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800"><i class="ri-error-warning-fill mr-1"></i>Pendiente</span>
                    <% end %>
                  </td>
                  <td class="px-6 py-4"><span class="text-sm text-gray-500"><%= charge.notes %></span></td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% if charge.charge_date.nil? %>
                      <%= button_to pay_charge_path(charge), method: :patch,
                            data: { turbo_confirm: "¿Registrar el pago de #{charge.member.full_name}?" },
                            class: "bg-green-600 hover:bg-green-700 text-white px-3 py-1 rounded-lg text-xs font-medium transition-colors cursor-pointer" do %>
                        <i class="ri-check-line mr-1"></i>Pagar
                      <% end %>
                    <% else %>
                      <%= button_to unpay_charge_path(charge), method: :patch,
                            data: { turbo_confirm: "¿Deshacer el pago de #{charge.member.full_name}?" },
                            class: "bg-amber-500 hover:bg-amber-600 text-white px-3 py-1 rounded-lg text-xs font-medium transition-colors cursor-pointer" do %>
                        <i class="ri-close-line mr-1"></i>Deshacer
                      <% end %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
              <% if @quote.charges.empty? %>
                <tr>
                  <td colspan="6" class="px-6 py-8 text-center text-sm text-gray-500">No hay cargos generados. Pulsa "Generar Cargos" para crearlos.</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>
</div>
